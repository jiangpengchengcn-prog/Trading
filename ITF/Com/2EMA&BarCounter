//@version=5
indicator("2EMA&BarCounter", overlay=true, max_labels_count=400)

// ==========================================
// --- Dimension 1 & 2: Dual TF EMA Settings ---
// ==========================================
ema_len = input.int(20, title="Current EMA Length", group="EMA Settings")
high_tf = input.timeframe("60", title="Higher Timeframe EMA", group="EMA Settings")

ema_current = ta.ema(close, ema_len)
ema_high_raw = ta.ema(close, ema_len)
ema_high = request.security(syminfo.tickerid, high_tf, ema_high_raw, gaps = barmerge.gaps_on)

plot(ema_current, color=color.gray, title="Current TF EMA", linewidth=1)
plot(ema_high, color=color.blue, title="Higher TF EMA", linewidth=1, style=plot.style_line)


// ==========================================
// --- Dimension 3: Bar Counter ---
// ==========================================
var GRP_DISPLAY = "Bar Counter - Display Settings"
var GRP_COLOR   = "Bar Counter - Color Settings"

// Display Options
show_bar_count        = input.bool(true, title="Enable Bar Count", group=GRP_DISPLAY)
sizeOption            = input.string(title='Label Size', options=['Auto', 'Huge', 'Large', 'Normal', 'Small', 'Tiny'], defval='Normal', group=GRP_DISPLAY)
c_contador            = input.int(2, title='Display at every X bars (Interval)', minval=1, group=GRP_DISPLAY)
enable_session_filter = input.bool(false, title="Enable Session Filter", group=GRP_DISPLAY)

// Dynamic Label Size Conversion
labelSize = sizeOption == 'Huge' ? size.huge : sizeOption == 'Large' ? size.large : sizeOption == 'Small' ? size.small : sizeOption == 'Tiny' ? size.tiny : sizeOption == 'Auto' ? size.auto : size.normal

// Color & Special Number Options
c_labelColor        = input.color(color.gray, 'Default Text Color', group=GRP_COLOR)
specialMultiple     = input.int(12, title="Special Color Multiple (e.g., 12, 24)", minval=1, maxval=100, group=GRP_COLOR)
specialColor        = input.color(color.blue, title="Color for Multiples of 12", group=GRP_COLOR)
specialCount1       = input.int(18, title="Special Number (Red Line)", minval=1, maxval=1000, group=GRP_COLOR)
specialColor_red    = input.color(color.red, title="Color for Bar 18", group=GRP_COLOR)

// Detect if futures market
is_futures = syminfo.type == "futures"

// Check for a new trading day to reset the count
is_new_day() =>
    d = dayofweek
    na(d[1]) or d != d[1]

// Session control check
is_in_trading_time() =>
    if not enable_session_filter
        true
    else
        if is_futures
            time(timeframe.period, "0830-1515", "America/Chicago")
        else
            time(timeframe.period, "0930-1600", "America/New_York")

// Counter Variables
var int count = 1
var bool counting = false

// Reset counter at the start of a new day
if is_new_day()
    count := 1
    counting := false

// Sequence management based on trading session
if is_in_trading_time()
    if not counting
        counting := true
        count := 1
    else
        count += 1
else
    counting := false

// Render Labels onto the Chart
// Displays Bar 1, intervals, multiples of 12, or specifically Bar 18
is_interval_match = (count == 1 or count % c_contador == 1) // Ensures step like 1, 3, 5 when interval is 2
is_special_multiple = (count % specialMultiple == 0)
is_special_18 = (count == specialCount1)

should_display_label = show_bar_count and counting and (is_interval_match or is_special_multiple or is_special_18)

if should_display_label
    // Color Priority: Bar 18 (Red) > Multiples of 12 (Blue) > Standard Gray
    labelColor = is_special_18 ? specialColor_red : (is_special_multiple ? specialColor : c_labelColor)
    
    label1 = label.new(bar_index, 0, style=label.style_none, text=str.tostring(count))
    label.set_textcolor(label1, labelColor)
    label.set_yloc(label1, yloc.belowbar)
    label.set_size(label1, labelSize)
